NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
COMPANYCAM_API_KEY=your_companycam_api_key
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=your_verified_sender@yourdomain.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1your_twilio_number
PIN_HASH_SALT=change-this-to-a-random-secret-string
CRON_SECRET=change-this-to-a-random-secret-string
MANAGER_EMAIL=manager@yourdomain.com

# ─── Observability (optional) ───────────────────────────────────────────────
# All of these are optional. lib/observability.ts always emits structured
# JSON logs to Vercel runtime logs regardless of these settings.
#
# SENTRY_DSN: if set, errors from reportError() are forwarded to Sentry.
#   Requires `npm i @sentry/nextjs` (dynamic import, no hard dep).
# ERROR_WEBHOOK_URL: if set, errors POST to this URL (Slack/Discord/etc).
#   Fire-and-forget, never blocks the request path.
SENTRY_DSN=
ERROR_WEBHOOK_URL=
